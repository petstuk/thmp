# Copy to .env and adjust. Never commit .env.

THMP_ENV=development
THMP_JWT_SECRET=change-me-to-a-long-random-string-in-production
THMP_INTERNAL_API_SECRET=change-me-internal-service-to-service

# PostgreSQL (docker-compose)
POSTGRES_USER=thmp
POSTGRES_PASSWORD=thmp
POSTGRES_DB=thmp

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO / S3-compatible object storage (docker-compose uses embedded MinIO)
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=thmp-minio
S3_SECRET_KEY=thmp-minio-secret
S3_BUCKET_EVIDENCE=thmp-evidence
S3_REGION=us-east-1
# For AWS S3 in production, omit S3_ENDPOINT_URL and set standard AWS_* env vars instead.

# OpenSearch / Elasticsearch
OPENSEARCH_URL=http://opensearch:9200
# For Elastic Cloud: OPENSEARCH_URL=https://my-cluster.es.io:9243 plus auth headers (configure in search.py).
# To disable search indexing, leave OPENSEARCH_URL unset.
OPENSEARCH_ADMIN_PASSWORD=LocalDev!Search9

# Service URLs (Compose sets these for containers)
AUDIT_SERVICE_URL=http://audit-service:8000
ATTACK_SERVICE_URL=http://attack-service:8000
HYPOTHESIS_SERVICE_URL=http://hypothesis-service:8000
USER_SERVICE_URL=http://user-service:8000
# User service: proxy integration "test connection" to ingestion (`POST /api/v1/integrations/{id}/test`).
INGESTION_SERVICE_URL=http://ingestion-service:8000

# Ingestion service (Compose). Optional default actor UUID when integration config omits ingest_actor_user_id.
# THMP_INGEST_DEFAULT_ACTOR_USER_ID=

# MITRE ATT&CK STIX 2.1 bundle (Enterprise). Override to pin a mirror or air-gapped file URL.
# ATTACK_STIX_URL=https://raw.githubusercontent.com/mitre/cti/master/enterprise-attack/enterprise-attack.json

# Optional: MITRE Navigator app version string embedded in exported layer JSON (default 4.9).
# THMP_NAVIGATOR_APP_VERSION=4.9

# URLs used by app containers (docker-compose overrides in compose file)
DATABASE_URL=postgresql+asyncpg://thmp:thmp@postgres:5432/thmp
USER_SERVICE_DATABASE_URL=postgresql+asyncpg://thmp:thmp@postgres:5432/thmp
HYPOTHESIS_SERVICE_DATABASE_URL=postgresql+asyncpg://thmp:thmp@postgres:5432/thmp
AUDIT_SERVICE_DATABASE_URL=postgresql+asyncpg://thmp:thmp@postgres:5432/thmp

# Issued JWT must list this issuer/audience for all services
THMP_JWT_ISSUER=thmp
THMP_JWT_AUDIENCE=thmp-api

# OIDC / OAuth2 identity provider (optional — leave unset to use local auth only)
# OIDC_ISSUER_URL=https://accounts.google.com
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_REDIRECT_URI=http://localhost:5173/auth/oidc/callback
# OIDC_DEFAULT_ROLE=analyst

# Frontend: leave empty so the browser calls /api on the Vite origin (5173) and Vite proxies to the gateway.
# Set to e.g. https://api.example.com only for production builds served without a same-host /api proxy.
# Do not point this at hypothesis-service :8002 alone — user-service routes (e.g. /api/v1/integrations) will 404.
VITE_API_BASE_URL=

# Optional UI branding: when set (e.g. Acme), the app title shows "Acme Antenna". When empty, "Antenna".
# VITE_COMPANY_NAME=

# Host-side `npm run dev` only: where Vite should proxy /api/v1/integrations (user-service published port).
# Docker Compose sets this inside the frontend container; you normally do not set it on the host.
# VITE_USER_SERVICE_PROXY=http://127.0.0.1:8001

# Host-side `npm run dev`: proxy /api → this URL (Docker Compose sets http://traefik:80 in compose env).
# DEV_PROXY_TARGET=http://127.0.0.1:80

# CORS (user service / others) — comma-separated origins
THMP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
