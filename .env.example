# Copy to .env and adjust. Never commit .env.

THMP_ENV=development
THMP_JWT_SECRET=change-me-to-a-long-random-string-in-production
THMP_INTERNAL_API_SECRET=change-me-internal-service-to-service

# PostgreSQL (docker-compose)
POSTGRES_USER=thmp
POSTGRES_PASSWORD=thmp
POSTGRES_DB=thmp

# Service URLs (Compose sets these for containers)
AUDIT_SERVICE_URL=http://audit-service:8000

# URLs used by app containers (docker-compose overrides in compose file)
DATABASE_URL=postgresql+asyncpg://thmp:thmp@postgres:5432/thmp
USER_SERVICE_DATABASE_URL=postgresql+asyncpg://thmp:thmp@postgres:5432/thmp
HYPOTHESIS_SERVICE_DATABASE_URL=postgresql+asyncpg://thmp:thmp@postgres:5432/thmp
AUDIT_SERVICE_DATABASE_URL=postgresql+asyncpg://thmp:thmp@postgres:5432/thmp

# Issued JWT must list this issuer/audience for all services
THMP_JWT_ISSUER=thmp
THMP_JWT_AUDIENCE=thmp-api

# Frontend: leave empty so the browser calls /api on the Vite origin (5173) and Vite proxies to the gateway.
# Set to e.g. https://api.example.com only for production builds served without a same-host /api proxy.
VITE_API_BASE_URL=

# Host-side `npm run dev`: proxy /api → this URL (Docker Compose sets http://traefik:80 in compose env).
# DEV_PROXY_TARGET=http://127.0.0.1:80

# CORS (user service / others) — comma-separated origins
THMP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
